# Firebase web config — copy to `.env` and fill in your project's values.
# Find these in the Firebase console → Project settings → "Your apps" → Web app.
#
# Auth: enable Email/Password under Firebase Authentication → Sign-in method.
# AI:   enable "Firebase AI Logic" (Gemini Developer API / Google AI) for the
#       TenantBridge assistant.
#
# Until these are set, the app runs in DEMO mode: any email/password signs in,
# and the AI assistant explains how to enable live replies.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to force emulators on localhost, "false" to use production Firestore.
# Omit (or leave blank) to auto-detect: emulators on localhost, production elsewhere.
VITE_USE_EMULATOR=
